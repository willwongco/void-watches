{% doc %}
  @prompt
    I want to add a marquee with images, I want to be able to add more images if needed in the future.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    position: relative;
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
  }

  .ai-marquee-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.image_gap }}px;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-marquee-container-{{ ai_gen_id }}:hover .ai-marquee-track-{{ ai_gen_id }} {
    {% if block.settings.pause_on_hover %}
      animation-play-state: paused;
    {% endif %}
  }

  .ai-marquee-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_width }}px;
    height: {{ block.settings.image_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-marquee-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-marquee-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-marquee-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-marquee-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #666;
    font-size: 14px;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-item-{{ ai_gen_id }} {
      width: {{ block.settings.image_width | times: 0.7 }}px;
      height: {{ block.settings.image_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<marquee-images-{{ ai_gen_id }}
  class="ai-marquee-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% liquid
    assign has_images = false
    for i in (1..20)
      assign image_key = 'image_' | append: i
      if block.settings[image_key] != blank
        assign has_images = true
        break
      endif
    endfor
  %}

  {% if has_images %}
    <div class="ai-marquee-track-{{ ai_gen_id }}">
      {% for duplicate in (1..2) %}
        {% for i in (1..20) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign image = block.settings[image_key]
          %}
          {% if image != blank %}
            <div class="ai-marquee-item-{{ ai_gen_id }}">
              <img
                src="{{ image | image_url: width: 400 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image_width }}"
                height="{{ block.settings.image_height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </div>
  {% else %}
    <div class="ai-marquee-empty-state-{{ ai_gen_id }}">
      Add images to create your marquee
    </div>
  {% endif %}
</marquee-images-{{ ai_gen_id }}>

<script>
  (function() {
    class MarqueeImages{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-marquee-track-{{ ai_gen_id }}');
        if (this.track) {
          this.ensureSmoothLoop();
        }
      }

      ensureSmoothLoop() {
        const trackWidth = this.track.scrollWidth / 2;
        const containerWidth = this.offsetWidth;
        
        if (trackWidth < containerWidth * 2) {
          const itemsNeeded = Math.ceil((containerWidth * 4) / trackWidth);
          const originalContent = this.track.innerHTML;
          
          for (let i = 0; i < itemsNeeded; i++) {
            this.track.innerHTML += originalContent;
          }
        }
      }
    }

    customElements.define('marquee-images-{{ ai_gen_id }}', MarqueeImages{{ ai_gen_id }});
  })();
</script>

