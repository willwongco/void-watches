{% doc %}
  @prompt
    I want to add an image across the page., I want the image centered and optimised to be approx 1000px wide and 200px heigh., The imgage is not centered in the section., The image is still not centered in the section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-centered-image-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .ai-centered-image__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    width: 100%;
    height: {{ block.settings.height }}px;
    overflow: hidden;
  }

  .ai-centered-image__img-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-centered-image__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-centered-image__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 150px;
  }

  .ai-centered-image__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-centered-image__container-{{ ai_gen_id }} {
      max-width: 100%;
      height: auto;
      min-height: {{ block.settings.height }}px;
    }
  }
{% endstyle %}

<div class="ai-centered-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-centered-image__container-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 1200 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-centered-image__img-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-centered-image__placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-centered-image__empty-state-{{ ai_gen_id }}">
          Add an image
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Centered image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Image dimensions"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 400,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1000
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height",
      "min": 100,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 200
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        },
        {
          "value": "fill",
          "label": "Fill"
        }
      ],
      "default": "contain"
    }
  ],
  "presets": [
    {
      "name": "Centered image"
    }
  ]
}
{% endschema %}